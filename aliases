# aliases and functions to use across shell environments
alias ..='cd ..'  # go up one directory
alias ...='cd ../..'  # go up two directories
alias ....='cd ../../..'  # go up three directories
alias c='clear'  # clear the screen
alias ll='ls -lha'  # use long list format
alias l.='ls -d .* --color=auto'  # show hidden files
alias bc='bc -l'  # start calculator with maths support
alias df='df -H'  # human readable df by default
alias du='du -c'  # human readable du with a grand total
alias xs='eza'
alias xl='eza --long --header --group --all'
alias gst='git status'
alias gcam='git commit -am'
alias sq='squeue'
alias smk='snakemake'
alias tsvtk='csvtk --tabs'

# functions to count the number of files/dirs in a directory
function xc {
    eza "$@" | wc -l
}
function lc {
    ls "$@" | wc -l
}
# make a directory and then change into it
function mkcd {
    mkdir -p "$@" && cd "$@"
}

# function that allows doing maths on the command line
function calc { printf "%s\n" "$@" | bc -l; }

joinjob() {
    local job_ids
    # Fetch all running jobs named 'interactive' for the current user
    job_ids=($(squeue -u "$USER" -n "interactive" -h -t RUNNING -o "%i"))

    if (( ${#job_ids[@]} == 0 )); then
        echo "[ERROR] No running job named 'interactive' found for user $USER." >&2
        return 1
    fi

    if (( ${#job_ids[@]} > 1 )); then
        echo "[WARN] Multiple 'interactive' jobs found. Joining the most recent one (${job_ids[0]})." >&2
    fi

    local target_job="${job_ids[0]}"
    echo "[INFO] Attaching to interactive job: $target_job"
    
    # Execute srun with overlap to join the allocation
    srun --jobid="$target_job" --overlap --pty zsh
}

# Function to go up N directories
up() {
    local n=$1
    local path=""
    for ((i=1; i<=n; i++)); do
        path+="../"
    done
    cd "$path"
}

# Aliases for convenience
alias u1='up 1'
alias u2='up 2'
alias u3='up 3'
alias u4='up 4'
alias u5='up 5'
alias u6='up 6'
alias u7='up 7'
alias u8='up 8'
alias u9='up 9'

